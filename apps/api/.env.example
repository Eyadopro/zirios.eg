# ---------------------------------------------------------------------------
# ZIRIOS API — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ---------------------------------------------------------------------------

# SQLite file path. For Postgres, swap to a `postgresql://...` URL and
# change the provider in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Secrets used to sign JWTs. Generate strong random strings in production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="dev-jwt-secret-change-me"
JWT_REFRESH_SECRET="dev-jwt-refresh-secret-change-me"

# Access token TTL (e.g. "15m") and refresh token TTL (e.g. "7d").
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Frontend origin, used for CORS. Must match where the Next.js app is served.
FRONTEND_URL="http://localhost:3000"

# Port the API listens on. The web app expects 4000 by default.
PORT=4000
